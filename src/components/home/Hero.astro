---
import { siteMeta } from '../../config/siteContent';
import { projectLinks } from '../../config/projectLinks';
---

<section class="border-b border-ink-200 bg-white">
  <div class="section-shell text-center">
    <h1 class="font-display text-4xl font-semibold tracking-tight text-ink-950 sm:text-5xl lg:text-6xl">
      {siteMeta.name}
    </h1>
    <p class="mx-auto mt-5 max-w-2xl text-xl font-medium text-ink-700 sm:text-2xl">
      {siteMeta.tagline}
    </p>
    <p class="mx-auto mt-5 max-w-2xl text-base leading-relaxed text-ink-600 sm:text-lg">
      {siteMeta.description}
    </p>

    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <a href="#demo" class="btn-primary">Try the Demo</a>
      <a href="#documentation" class="btn-secondary">Get Started</a>
      <span class="btn-secondary cursor-not-allowed text-ink-400" title="Repository coming soon">
        View on GitHub
      </span>
    </div>

    <p class="mx-auto mt-10 max-w-xl text-sm text-ink-500">
      Based on the {siteMeta.corePaper.venue} paper<br />
      <em class="font-display not-italic text-ink-700">{siteMeta.corePaper.title}</em>
    </p>
  </div>
</section>
