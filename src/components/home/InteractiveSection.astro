---
import ConfigExplainer from '../config-explainer/ConfigExplainer';
import { projectLinks } from '../../config/projectLinks';
---

<section id="interactive" class="border-b border-ink-200 bg-white">
  <div class="section-shell">
    <p class="section-label">Interactive preview</p>
    <h2 class="section-title">Configuration Explanation Interface</h2>
    <p class="section-lead">
      Hover, click, or focus highlighted fields to inspect localized subspecifications. This preview
      uses the user-study warm-up example on router R1—without study timers or data collection.
    </p>

    <div class="mt-10">
      <ConfigExplainer client:load />
    </div>

    <div class="mt-8 flex flex-wrap items-center gap-4">
      <a
        href={projectLinks.userStudy}
        class="btn-secondary"
        target="_blank"
        rel="noopener noreferrer"
      >
        Explore the User-Study Tasks
      </a>
      <p class="text-sm text-ink-500">
        <span class="inline-block h-3 w-3 rounded-sm bg-spec align-middle"></span> Field subspec
        <span class="mx-2">·</span>
        <span class="inline-block h-3 w-3 rounded-sm bg-spec-line align-middle"></span> Line-level
        <span class="mx-2">·</span>
        <span class="inline-block h-3 w-3 rounded-sm bg-spec-muted align-middle"></span> Unrestricted
      </p>
    </div>
  </div>
</section>
