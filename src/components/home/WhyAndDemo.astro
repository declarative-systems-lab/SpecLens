---
import ConfigExplainer from '../config-explainer/ConfigExplainer.tsx';
import { projectLinks } from '../../config/projectLinks';
---

<section id="why" class="border-b border-ink-200/70 bg-white">
  <div class="section-shell">
    <p class="section-label" data-i18n="why.label">Why SpecLens</p>
    <h2 class="section-title" data-i18n="why.title">
      Network verification tells you whether a configuration is correct. SpecLens explains why.
    </h2>
    <p class="section-lead" data-i18n="why.lead">
      After verification succeeds, operators still need to understand which configuration elements matter, what each one must preserve, and which local edits remain safe.
    </p>

    <div class="mt-12 grid gap-8 lg:grid-cols-2">
      <div>
        <h3 class="font-display text-lg font-semibold text-ink-900" data-i18n="why.questionsTitle">
          Questions that remain after verification
        </h3>
        <ul class="mt-4 space-y-3 text-sm leading-relaxed text-ink-700">
          <li class="flex gap-2"><span class="text-accent">→</span> <span data-i18n="why.q1">Which configuration elements make the property hold?</span></li>
          <li class="flex gap-2"><span class="text-accent">→</span> <span data-i18n="why.q2">What must each relevant element preserve?</span></li>
          <li class="flex gap-2"><span class="text-accent">→</span> <span data-i18n="why.q3">Which local edits are safe?</span></li>
          <li class="flex gap-2"><span class="text-accent">→</span> <span data-i18n="why.q4">Which lines or fields are irrelevant to this property?</span></li>
          <li class="flex gap-2"><span class="text-accent">→</span> <span data-i18n="why.q5">Are there dependencies on policies at other routers?</span></li>
        </ul>
        <p class="mt-6 text-sm leading-relaxed text-ink-600" data-i18n="why.summary">
          SpecLens associates configuration locations with localized correctness constraints, allowing operators to reason about focused configuration fragments instead of manually simulating the entire network.
        </p>
      </div>

      <div class="grid gap-4">
        <div class="surface-card p-5">
          <p class="text-xs font-semibold uppercase tracking-wider text-ink-500" data-i18n="why.before">Before</p>
          <pre class="mt-3 overflow-x-auto rounded-lg bg-ink-950 p-4 font-mono text-sm leading-relaxed text-ink-100">Verification result:
✓ Prefix P is reachable from R2.</pre>
        </div>
        <div class="surface-card border-accent/20 p-5 ring-1 ring-accent/10">
          <p class="text-xs font-semibold uppercase tracking-wider text-accent" data-i18n="why.after">After</p>
          <pre class="mt-3 overflow-x-auto rounded-lg border border-config-border bg-config-bg p-4 font-mono text-sm leading-relaxed text-ink-900">Localized explanation:
R1 / prefix-list CUSTOMER / prefix field

Required constraint:
The configured prefix must cover P.</pre>
        </div>
      </div>
    </div>
  </div>
</section>

<section id="demo" class="border-b border-ink-200/70 bg-ink-50/60">
  <div class="section-shell">
    <p class="section-label" data-i18n="demo.label">Interactive preview</p>
    <h2 class="section-title" data-i18n="demo.title">Inspect localized explanations on real configuration</h2>
    <p class="section-lead" data-i18n="demo.lead">
      A lightweight public preview of the user-study explanation interface, using the warm-up task configuration from our operator study — no participant login or data collection.
    </p>

    <div class="mt-10">
      <ConfigExplainer client:load />
    </div>

    <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-2">
      <a href={projectLinks.userStudy} class="btn-secondary" target="_blank" rel="noopener noreferrer" data-i18n="demo.exploreStudy">
        Explore the User-Study Tasks
      </a>
      <div class="flex flex-wrap items-center gap-4 text-xs text-ink-500">
        <span class="inline-flex items-center gap-1.5">
          <span class="h-3 w-6 rounded-sm bg-[#B8DCF9]" aria-hidden="true"></span>
          <span data-i18n="demo.legendField">Field subspec</span>
        </span>
        <span class="inline-flex items-center gap-1.5">
          <span class="h-3 w-6 rounded-sm bg-[#E2C0E8]" aria-hidden="true"></span>
          <span data-i18n="demo.legendLine">Line-level</span>
        </span>
        <span class="inline-flex items-center gap-1.5">
          <span class="h-3 w-6 rounded-sm bg-spec-muted ring-1 ring-ink-200" aria-hidden="true"></span>
          <span data-i18n="demo.legendEmpty">Unrestricted</span>
        </span>
      </div>
    </div>
  </div>
</section>
