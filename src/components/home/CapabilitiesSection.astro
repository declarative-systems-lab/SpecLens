---
import { capabilities } from '../../config/siteContent';
---

<section id="capabilities" class="border-b border-ink-200/70 bg-white">
  <div class="section-shell">
    <p class="section-label" data-i18n="capabilities.label">Capabilities</p>
    <h2 class="section-title" data-i18n="capabilities.title">What SpecLens Can Explain</h2>
    <p class="section-lead" data-i18n="capabilities.lead">
      Capabilities supported by the core SIGCOMM system and its current implementation — not research extensions such as repair-space characterization or fault-tolerant subspecifications.
    </p>

    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        capabilities.map((cap, i) => (
          <article class="surface-card flex flex-col p-6 transition hover:shadow-lift">
            <span class="flex h-8 w-8 items-center justify-center rounded-full bg-accent-soft text-sm font-bold text-accent">
              {i + 1}
            </span>
            <h3 class="mt-4 font-display text-lg font-semibold text-ink-900">{cap.title}</h3>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-ink-600">{cap.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
