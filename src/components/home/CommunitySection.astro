---
import { contributors } from '../../config/siteContent';
import { projectLinks } from '../../config/projectLinks';
---

<section id="community" class="bg-ink-900 text-white">
  <div class="section-shell">
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-spec">Community</p>
    <h2 class="mt-3 font-display text-3xl font-semibold sm:text-4xl">People &amp; Community</h2>
    <p class="mt-4 max-w-2xl text-ink-300">
      SpecLens is developed at {contributors.affiliation}. The SIGCOMM core author list will be
      published with the camera-ready paper.
    </p>

    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        contributors.team.map((person) => (
          <div class="rounded-lg border border-white/10 bg-white/5 p-5">
            <p class="font-semibold">{person.name}</p>
            {'role' in person && person.role && (
              <p class="text-sm text-spec">{person.role}</p>
            )}
            <p class="mt-1 text-sm text-ink-300">{person.affiliation}</p>
            {'email' in person && person.email && (
              <a href={`mailto:${person.email}`} class="mt-2 inline-block text-sm text-spec hover:underline">
                {person.email}
              </a>
            )}
          </div>
        ))
      }
    </div>

    <div class="mt-10 flex flex-wrap gap-4">
      <a href={projectLinks.contact} class="btn-primary bg-white text-ink-900 hover:bg-ink-100">
        Contact
      </a>
      <a
        href={projectLinks.github}
        class:list={['btn-secondary border-white/20 bg-transparent text-white hover:bg-white/10', projectLinks.github === '#' && 'opacity-50 pointer-events-none']}
      >
        GitHub (coming soon)
      </a>
      <a href="/docs/getting-started" class="btn-ghost text-ink-200 hover:bg-white/10 hover:text-white">
        Contribution guide (docs)
      </a>
    </div>
  </div>
</section>
