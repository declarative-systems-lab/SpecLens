---
import { getStartedPlaceholder } from '../../config/siteContent';
---

<section class="border-b border-ink-200 bg-ink-50/50">
  <div class="section-shell">
    <p class="section-label">Get Started</p>
    <h2 class="section-title">Run SpecLens</h2>
    <p class="section-lead">{getStartedPlaceholder.message}</p>

    <div class="mt-8 surface-card p-6 sm:p-8">
      <h3 class="text-sm font-semibold uppercase tracking-wider text-ink-500">Expected prerequisites</h3>
      <ul class="mt-4 flex flex-wrap gap-2">
        {
          getStartedPlaceholder.prerequisites.map((item) => (
            <li class="rounded-full bg-ink-100 px-3 py-1 text-sm text-ink-700">{item}</li>
          ))
        }
      </ul>

      <div class="mt-8 rounded-lg border border-dashed border-ink-300 bg-ink-50 px-5 py-8 text-center">
        <p class="text-sm font-medium text-ink-700">Installation and CLI commands</p>
        <p class="mt-2 text-sm text-ink-500">
          Will be published with the open-source artifact. No placeholder commands are shown here.
        </p>
        <a href="/docs/getting-started" class="btn-primary mt-6 inline-flex">Read documentation</a>
      </div>
    </div>
  </div>
</section>
