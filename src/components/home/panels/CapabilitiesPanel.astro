---
import { capabilities } from '../../../config/siteContent';
---

<div class="panel-inner">
  <p class="section-label" data-i18n="capabilities.label">Capabilities</p>
  <h2 class="section-title text-2xl sm:text-3xl" data-i18n="capabilities.title">What SpecLens Can Explain</h2>

  <div class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
    {
      capabilities.map((cap, i) => (
        <article class="surface-card p-4">
          <span class="text-xs font-bold text-accent">{i + 1}</span>
          <h3 class="mt-1 font-display text-sm font-semibold text-ink-900">{cap.title}</h3>
          <p class="mt-1.5 text-xs leading-relaxed text-ink-600 line-clamp-3">{cap.description}</p>
        </article>
      ))
    }
  </div>
</div>
