---
import { coreResearch, researchExtensions } from '../../../config/extensions';
import { contributors } from '../../../config/siteContent';
import { projectLinks } from '../../../config/projectLinks';
---

<div class="panel-inner">
  <p class="section-label" data-i18n="research.label">Research</p>
  <h2 class="section-title text-xl sm:text-2xl" data-i18n="research.title">Research &amp; people</h2>

  <div class="mt-4 space-y-3">
    <article class="surface-card flex flex-wrap items-center justify-between gap-3 p-4">
      <div class="min-w-0 flex-1">
        <p class="text-[0.65rem] font-semibold uppercase tracking-wide text-accent">{coreResearch.venue}</p>
        <h3 class="mt-0.5 text-sm font-semibold text-ink-900 line-clamp-2">{coreResearch.title}</h3>
      </div>
      <a href={coreResearch.pdf} class="btn-secondary shrink-0 px-3 py-1.5 text-xs">PDF</a>
    </article>

    {
      researchExtensions.map((ext) => (
        <article class="surface-card flex flex-wrap items-center justify-between gap-3 p-4">
          <div class="min-w-0 flex-1">
            <p class="text-[0.65rem] text-ink-500">{ext.venue}{ext.date ? ` · ${ext.date}` : ''}</p>
            <h3 class="mt-0.5 text-sm font-semibold text-ink-900 line-clamp-2">{ext.title}</h3>
          </div>
          <div class="flex shrink-0 gap-2">
            {ext.pdf && <a href={ext.pdf} class="text-xs font-medium text-accent hover:underline">PDF</a>}
            {ext.doi && (
              <a href={ext.doi} class="text-xs font-medium text-ink-500 hover:underline" target="_blank" rel="noopener noreferrer">
                DOI
              </a>
            )}
          </div>
        </article>
      ))
    }
  </div>

  <div class="mt-5 border-t border-ink-200 pt-4">
    <h3 class="text-sm font-semibold text-ink-900" data-i18n="research.peopleTitle">People &amp; contact</h3>
    <ul class="mt-3 grid gap-2 sm:grid-cols-3">
      {
        contributors.team.map((person) => (
          <li class="text-xs text-ink-700">
            <span class="font-medium text-ink-900">{person.name}</span>
            <br />
            <a href={`mailto:${person.email}`} class="text-accent hover:underline">{person.email}</a>
          </li>
        ))
      }
    </ul>
    <a href={projectLinks.contact} class="mt-3 inline-block text-xs font-medium text-accent" data-i18n="research.contactTeam">
      Contact the team →
    </a>
  </div>
</div>
