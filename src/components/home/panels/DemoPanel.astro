---
import ConfigExplainer from '../../config-explainer/ConfigExplainer.tsx';
import { projectLinks } from '../../../config/projectLinks';
---

<div class="panel-inner panel-inner--wide">
  <p class="section-label" data-i18n="demo.label">Interactive preview</p>
  <h2 class="section-title text-xl sm:text-2xl" data-i18n="demo.title">Inspect localized explanations on real configuration</h2>

  <div class="mt-4 min-h-0 flex-1">
    <ConfigExplainer client:load />
  </div>

  <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-ink-500">
    <a href={projectLinks.userStudy} class="text-accent hover:text-accent-dark" target="_blank" rel="noopener noreferrer" data-i18n="demo.exploreStudy">
      Explore the User-Study Tasks →
    </a>
    <span class="inline-flex items-center gap-1"><span class="h-2.5 w-4 rounded-sm bg-[#B8DCF9]"></span><span data-i18n="demo.legendField">Field</span></span>
    <span class="inline-flex items-center gap-1"><span class="h-2.5 w-4 rounded-sm bg-[#E2C0E8]"></span><span data-i18n="demo.legendLine">Line</span></span>
  </div>
</div>
