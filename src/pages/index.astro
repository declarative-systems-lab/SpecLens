---
import BaseLayout from '../layouts/BaseLayout.astro';
import ConfigExplainer from '../components/config-explainer/ConfigExplainer.tsx';
import EvalChartLegend from '../components/EvalChartLegend.astro';
import { assetUrl } from '../utils/assetUrl';
import {
  siteMeta,
  workflowSteps,
  userStudyMetrics,
  benchmarkMetrics,
  showWorkflowSection,
  contact,
} from '../config/siteContent';
import { projectLinks } from '../config/projectLinks';
import { coreResearch, researchExtensions } from '../config/extensions';
---

<BaseLayout title="SpecLens" description={siteMeta.description}>
  <div class="home">
    <div class="container banner-container">
      <h1>{siteMeta.name}</h1>
      <p class="hero-lead" data-i18n="hero.tagline">{siteMeta.tagline}</p>
      <p data-i18n="hero.description">{siteMeta.description}</p>
      <p class="hero-links">
        <a href={projectLinks.paper} data-i18n="hero.paperLink">Paper</a>
        {' · '}
        <a href={projectLinks.github} target="_blank" rel="noopener noreferrer" data-i18n="hero.codeLink">Code</a>
      </p>
      <p class="hero-contact">
        <span class="hero-contact__label" data-i18n="hero.contactLabel">Contact:</span>
        {' '}
        <a href={`mailto:${contact.email}`}>{contact.email}</a> · <span data-i18n="home.affiliation">{contact.affiliation}</span>
      </p>
      <p class="hero-paper">
        <span data-i18n="hero.paperVenue">Based on the {siteMeta.corePaper.venue} paper</span><br />
        <em data-i18n="hero.paperTitle">{siteMeta.corePaper.title}</em>
      </p>
    </div>

    <div class="bg-gradient-1" aria-hidden="true"></div>

    <div class="container">
      <section id="why" class="section">
        <div class="section-title"><h2 data-i18n="home.whyHeading">Why {siteMeta.name}</h2></div>
        <div class="content-row">
          <p data-i18n="home.whyLead">
            Network verification tells you whether a configuration is correct. {siteMeta.name} explains
            why.
          </p>
        </div>
        <ul class="content-list">
          <li data-i18n="home.whyQ1">Which configuration elements matter?</li>
          <li data-i18n="home.whyQ2">What must each element preserve?</li>
          <li data-i18n="home.whyQ3">Which local edits are safe?</li>
          <li data-i18n="home.whyQ4">Which fields are irrelevant?</li>
        </ul>
      </section>

      <section id="demo" class="section">
        <div class="section-title"><h2 data-i18n="home.demoHeading">Demo</h2></div>
        <div class="content-row">
          <h4 data-i18n="home.demoSubtitle">Inspect localized explanations on example configuration</h4>
        </div>
        <ConfigExplainer client:load />
        <div class="demo-footer">
          <div class="demo-links">
            <a href={projectLinks.userStudy} target="_blank" rel="noopener noreferrer" data-i18n="home.userStudyDemo">
              User-Study Demo →
            </a>
            <a href={projectLinks.multiSubspec} target="_blank" rel="noopener noreferrer" data-i18n="home.multiSubspecDemo">
              Explore Multi-Subspec Demo →
            </a>
          </div>
          <div class="legend-inline">
            <span><span class="legend-swatch legend-swatch--line"></span> <span data-i18n="demo.legendLine">Line-level</span></span>
            <span><span class="legend-swatch legend-swatch--field"></span> <span data-i18n="demo.legendField">Field subspec</span></span>
            <span><span class="legend-swatch legend-swatch--empty"></span> <span data-i18n="demo.legendEmpty">Unrestricted</span></span>
          </div>
        </div>
      </section>

      {
        showWorkflowSection && (
          <section id="workflow" class="section">
            <div class="section-title"><h2>Workflow</h2></div>
            <div class="content-row">
              <p>
                {siteMeta.name} complements existing network verification, synthesis, and repair systems
                rather than replacing them.
              </p>
            </div>
            <div class="workflow-layout">
              <div class="workflow-col">
                <figure class="figure-box figure-box--fill">
                  <img src={assetUrl('/figures/fig-overview-new.png')} alt={`${siteMeta.name} workflow overview`} loading="lazy" />
                  <figcaption>
                    Subspecification generation flow, using stable control-plane behavior as
                    router-level subspecification.
                  </figcaption>
                </figure>
                <ol class="workflow-steps-list">
                  {
                    workflowSteps.map((step, i) => (
                      <li>
                        <span class="step-num">{i + 1}</span>
                        <div>
                          <strong>{step.title}</strong>
                          <p>{step.description}</p>
                        </div>
                      </li>
                    ))
                  }
                </ol>
              </div>
              <figure class="figure-box figure-box--fill">
                <img src={assetUrl('/figures/fig-pipeline-new.png')} alt={`${siteMeta.name} technical pipeline`} loading="lazy" />
                <figcaption>Example of field-level subspec derivation.</figcaption>
              </figure>
            </div>
          </section>
        )
      }

      <section id="trust" class="section">
        <div class="section-title">
          <h2 data-i18n="home.trustHeading">Why Trust {siteMeta.name}</h2>
        </div>

        <ul class="trust-tabs" role="tablist">
          <li>
            <a href="#" class="active" data-trust-tab="users" role="tab" aria-selected="true" data-i18n="home.trustTabUsers">
              Validated with Users
            </a>
          </li>
          <li>
            <a href="#" data-trust-tab="sus" role="tab" aria-selected="false" data-i18n="home.trustTabSus">
              System Usability Scale (SUS)
            </a>
          </li>
          <li>
            <a href="#" data-trust-tab="scalability" role="tab" aria-selected="false" data-i18n="home.trustTabScalability">
              Scalability
            </a>
          </li>
          <li>
            <a href="#" data-trust-tab="runtime" role="tab" aria-selected="false" data-i18n="home.trustTabRuntime">
              Runtime
            </a>
          </li>
        </ul>

        <div class="trust-panel" data-trust-panel="users" role="tabpanel">
          <div class="trust-panel__intro">
            <p class="eval-lead" data-i18n="home.trustUsersLead">
              We evaluated {siteMeta.name} with {userStudyMetrics.participants} participants ({userStudyMetrics.operators} professional network operators and {userStudyMetrics.students} graduate students) on four configuration reasoning tasks.
            </p>
            <div class="eval-highlights">
              <span data-i18n="home.trustAccuracyHighlight" data-i18n-html="true"><strong>{userStudyMetrics.accuracyImprovement}</strong> accuracy improvement</span>
              <span data-i18n="home.trustTimeHighlight" data-i18n-html="true"><strong>{userStudyMetrics.timeReduction}</strong> time reduction</span>
            </div>
          </div>

          <figure class="figure-box figure-box--wide">
            <EvalChartLegend variant="userstudy" />
            <div class="eval-grid">
              <figure>
                <img src={assetUrl('/figures/fig-userstudy-accuracy-combined.png')} alt="Task accuracy (combined)" loading="lazy" />
                <figcaption data-i18n="home.chartAccuracyCombined">Task accuracy (combined).</figcaption>
              </figure>
              <figure>
                <img src={assetUrl('/figures/fig-userstudy-accuracy-academia.png')} alt="Task accuracy (grad students)" loading="lazy" />
                <figcaption data-i18n="home.chartAccuracyAcademia">Task accuracy (grad students).</figcaption>
              </figure>
              <figure>
                <img src={assetUrl('/figures/fig-userstudy-accuracy-industry.png')} alt="Task accuracy (operators)" loading="lazy" />
                <figcaption data-i18n="home.chartAccuracyIndustry">Task accuracy (operators).</figcaption>
              </figure>
              <figure>
                <img src={assetUrl('/figures/fig-userstudy-time-combined.png')} alt="Task completion time (combined)" loading="lazy" />
                <figcaption data-i18n="home.chartTimeCombined">Task completion time (combined).</figcaption>
              </figure>
              <figure>
                <img src={assetUrl('/figures/fig-userstudy-time-academia.png')} alt="Task completion time (grad students)" loading="lazy" />
                <figcaption data-i18n="home.chartTimeAcademia">Task completion time (grad students).</figcaption>
              </figure>
              <figure>
                <img src={assetUrl('/figures/fig-userstudy-time-industry.png')} alt="Task completion time (operators)" loading="lazy" />
                <figcaption data-i18n="home.chartTimeIndustry">Task completion time (operators).</figcaption>
              </figure>
            </div>
            <p class="figure-caption figure-caption--summary" data-i18n="home.trustUsersSummary">
              User study task accuracy and completion time.
            </p>
          </figure>

          <div class="content-row eval-copy">
            <p data-i18n="home.trustUsersCopy1">
              Participants scored higher when explanations were available. Combined accuracy rose from
              1.83 to 2.67 points (+52% relative improvement on the paper scale). Task 4 showed the
              largest gain (+78%).
            </p>
            <p data-i18n="home.trustUsersCopy2">
              Overall median completion time dropped by 24% (9.5 → 7.1 minutes). Graduate students saw
              nearly 2× speedup with subspecs; operators benefited most on the hardest task.
            </p>
          </div>
        </div>

        <div class="trust-panel" data-trust-panel="sus" role="tabpanel" hidden>
          <div class="trust-panel__intro">
            <p class="eval-lead" data-i18n="home.trustSusLead">
              Mean SUS was 62.3/100 overall (71.3 academia, 57.5 industry). 70% of participants
              reported they would use localized subspecifications frequently.
            </p>
            <div class="eval-highlights" aria-hidden="true"></div>
          </div>
          <figure class="figure-box figure-box--wide">
            <EvalChartLegend variant="sus" />
            <div class="eval-grid eval-grid--3">
              <figure>
                <img src={assetUrl('/figures/fig-userstudy-sus-combined.png')} alt="SUS (combined)" loading="lazy" />
                <figcaption data-i18n="home.chartSusCombined">System usability scale (combined).</figcaption>
              </figure>
              <figure>
                <img src={assetUrl('/figures/fig-userstudy-sus-academia.png')} alt="SUS (grad students)" loading="lazy" />
                <figcaption data-i18n="home.chartSusAcademia">System usability scale (grad students).</figcaption>
              </figure>
              <figure>
                <img src={assetUrl('/figures/fig-userstudy-sus-industry.png')} alt="SUS (operators)" loading="lazy" />
                <figcaption data-i18n="home.chartSusIndustry">System usability scale (operators).</figcaption>
              </figure>
            </div>
          </figure>
        </div>

        <div class="trust-panel" data-trust-panel="scalability" role="tabpanel" hidden>
          <div class="trust-panel__intro">
            <p class="eval-lead" data-i18n="home.trustScalabilityLead">
              We assessed scalability by varying network size, number of prefixes, and parallelism.
            </p>
            <div class="eval-highlights">
              <span data-i18n="home.trustScalabilityHighlight" data-i18n-html="true"><strong>{benchmarkMetrics.fiveHundredRouterMinutes} min</strong> at 500 routers</span>
            </div>
          </div>

          <figure class="figure-box figure-box--wide">
            <EvalChartLegend variant="benchmark-line" />
            <div class="eval-grid eval-grid--3">
              <figure>
                <img src={assetUrl('/figures/fig_benchmark_lineplot_fattrees.png')} alt="Scalability varying network size" loading="lazy" />
                <figcaption data-i18n="home.chartScaleNetwork">Vary network size.</figcaption>
              </figure>
              <figure>
                <img src={assetUrl('/figures/fig_benchmark_lineplot_synthetic.png')} alt="Scalability varying number of prefixes" loading="lazy" />
                <figcaption data-i18n="home.chartScalePrefixes">Vary prefixes.</figcaption>
              </figure>
              <figure>
                <img src={assetUrl('/figures/fig_benchmark_lineplot_cores.png')} alt="Scalability varying thread count" loading="lazy" />
                <figcaption data-i18n="home.chartScaleThreads">Vary threads (parallelism).</figcaption>
              </figure>
            </div>
            <p class="figure-caption figure-caption--summary" data-i18n="home.trustScalabilitySummary">
              Scalability of subspecification generation under different dimensions.
            </p>
          </figure>
        </div>

        <div class="trust-panel" data-trust-panel="runtime" role="tabpanel" hidden>
          <div class="trust-panel__intro">
            <p class="eval-lead" data-i18n="home.trustRuntimeLead">
              We benchmarked end-to-end subspecification generation on real and synthetic network configurations.
            </p>
            <div class="eval-highlights">
              <span data-i18n="home.trustRuntimeInternet2" data-i18n-html="true"><strong>{benchmarkMetrics.internet2Minutes} min</strong> Internet2</span>
              <span data-i18n="home.trustRuntimeSynthetic" data-i18n-html="true"><strong>{benchmarkMetrics.syntheticSecondsRange} sec</strong> synthetic configs</span>
            </div>
          </div>

          <figure class="figure-box figure-box--wide">
            <EvalChartLegend variant="benchmark-time" />
            <div class="eval-chart-single">
              <img
                src={assetUrl('/figures/fig_benchmark_times.png')}
                alt="Run time on each network configuration"
                loading="lazy"
              />
            </div>
            <p class="figure-caption figure-caption--summary" data-i18n="home.trustRuntimeSummary">Run time on each network configuration.</p>
          </figure>
        </div>

        <p class="content-row trust-footer">
          <a href={projectLinks.paper} data-i18n="home.readFullEval">Read the full evaluation →</a>
        </p>
      </section>

      <section id="research" class="section">
        <div class="section-title"><h2 data-i18n="home.researchHeading">Research Extensions</h2></div>
        <ul class="research-tabs" role="tablist">
          <li>
            <a href="#" class="active" data-research-tab="core" role="tab" aria-selected="true" data-i18n="home.researchTabCore">
              Explainable Network Verification
            </a>
          </li>
          <li>
            <a href="#" data-research-tab="repair" role="tab" aria-selected="false" data-i18n="home.researchTabRepair">
              Configuration Repair
            </a>
          </li>
          <li>
            <a href="#" data-research-tab="fault-tolerance" role="tab" aria-selected="false" data-i18n="home.researchTabFault">
              Fault-Tolerant Subspecifications
            </a>
          </li>
        </ul>

        <div class="research-panel" data-research-panel="core" role="tabpanel">
          <div class="content-row">
            <h4><a href={coreResearch.pdf}>{coreResearch.title}</a></h4>
            <p class="research-meta">
              {coreResearch.venue} · {coreResearch.date} · {coreResearch.location}
            </p>
            <p class="research-meta">{coreResearch.authors.join(', ')}</p>
            <p data-i18n="research.coreDescription">{coreResearch.description}</p>
            <p>
              <a href={coreResearch.pdf} data-i18n="home.pdf">PDF</a>
              {' · '}
              <a href={coreResearch.doi} target="_blank" rel="noopener noreferrer" data-i18n="home.doi">DOI</a>
            </p>
          </div>
        </div>

        {
          researchExtensions.map((ext) => (
            <div class="research-panel" data-research-panel={ext.id} role="tabpanel" hidden>
              <div class="content-row">
                <h4>{ext.pdf ? <a href={ext.pdf}>{ext.title}</a> : ext.title}</h4>
                <p class="research-meta">
                  {ext.venue}
                  {ext.date ? ` · ${ext.date}` : ''}
                  {ext.location ? ` · ${ext.location}` : ''}
                </p>
                {ext.authors.length > 0 && <p class="research-meta">{ext.authors.join(', ')}</p>}
                <p data-i18n={ext.id === 'repair' ? 'research.repairDescription' : 'research.faultDescription'}>{ext.description}</p>
                <p>
                  {ext.pdf && <a href={ext.pdf} data-i18n="home.pdf">PDF</a>}
                  {ext.doi && (
                    <>
                      {ext.pdf && ' · '}
                      <a href={ext.doi} target="_blank" rel="noopener noreferrer" data-i18n="home.doi">DOI</a>
                    </>
                  )}
                </p>
              </div>
            </div>
          ))
        }
      </section>
    </div>
  </div>

  <script>
    function setupSectionTabs(tabAttr, panelAttr) {
      document.querySelectorAll(`[${tabAttr}]`).forEach((tab) => {
        tab.addEventListener('click', (e) => {
          e.preventDefault();
          const id = tab.getAttribute(tabAttr);
          if (!id) return;

          document.querySelectorAll(`[${tabAttr}]`).forEach((t) => {
            t.classList.remove('active');
            t.setAttribute('aria-selected', 'false');
          });
          tab.classList.add('active');
          tab.setAttribute('aria-selected', 'true');

          document.querySelectorAll(`[${panelAttr}]`).forEach((panel) => {
            const panelId = panel.getAttribute(panelAttr);
            if (panelId === id) panel.removeAttribute('hidden');
            else panel.setAttribute('hidden', '');
          });
        });
      });
    }

    setupSectionTabs('data-trust-tab', 'data-trust-panel');
    setupSectionTabs('data-research-tab', 'data-research-panel');
  </script>
</BaseLayout>
