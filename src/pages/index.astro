---
import BaseLayout from '../layouts/BaseLayout.astro';
import ConfigExplainer from '../components/config-explainer/ConfigExplainer.tsx';
import EvalChartLegend from '../components/EvalChartLegend.astro';
import { assetUrl } from '../utils/assetUrl';
import {
  siteMeta,
  whyQuestions,
  workflowSteps,
  userStudyMetrics,
  benchmarkMetrics,
  trustTabs,
  showWorkflowSection,
  contact,
} from '../config/siteContent';
import { projectLinks } from '../config/projectLinks';
import { coreResearch, researchExtensions, researchTree } from '../config/extensions';
---

<BaseLayout title="SpecLens" description={siteMeta.description}>
  <div class="home">
    <div class="container banner-container">
      <h1>{siteMeta.name}</h1>
      <p class="hero-lead">{siteMeta.tagline}</p>
      <p>{siteMeta.description}</p>
      <p class="hero-links">
        <a href={projectLinks.paper}>Paper</a>
        {' · '}
        <a href={projectLinks.github} target="_blank" rel="noopener noreferrer">Code</a>
      </p>
      <p class="hero-contact">
        <span class="hero-contact__label">Contact:</span>
        {' '}
        <a href={`mailto:${contact.email}`}>{contact.email}</a> · {contact.affiliation}
      </p>
      <p class="hero-paper">
        Based on the {siteMeta.corePaper.venue} paper<br />
        <em>{siteMeta.corePaper.title}</em>
      </p>
    </div>

    <div class="bg-gradient-1" aria-hidden="true"></div>

    <div class="container">
      <section id="why" class="section">
        <div class="section-title"><h2>Why {siteMeta.name}</h2></div>
        <div class="content-row">
          <p>
            Network verification tells you whether a configuration is correct. {siteMeta.name} explains
            why.
          </p>
        </div>
        <ul class="content-list">
          {whyQuestions.map((q) => <li>{q}</li>)}
        </ul>
      </section>

      <section id="demo" class="section">
        <div class="section-title"><h2>Demo</h2></div>
        <div class="content-row">
          <h4>Inspect localized explanations on example configuration</h4>
        </div>
        <ConfigExplainer client:load />
        <div class="demo-footer">
          <div class="demo-links">
            <a href={projectLinks.userStudy} target="_blank" rel="noopener noreferrer">
              User-Study Demo →
            </a>
            <a href={projectLinks.multiSubspec} target="_blank" rel="noopener noreferrer">
              Explore Multi-Subspec Demo →
            </a>
          </div>
          <div class="legend-inline">
            <span><span class="legend-swatch legend-swatch--line"></span> Line-level</span>
            <span><span class="legend-swatch legend-swatch--field"></span> Field subspec</span>
            <span><span class="legend-swatch legend-swatch--empty"></span> Unrestricted</span>
          </div>
        </div>
      </section>

      {
        showWorkflowSection && (
          <section id="workflow" class="section">
            <div class="section-title"><h2>Workflow</h2></div>
            <div class="content-row">
              <p>
                {siteMeta.name} complements existing network verification, synthesis, and repair systems
                rather than replacing them.
              </p>
            </div>
            <div class="workflow-layout">
              <div class="workflow-col">
                <figure class="figure-box figure-box--fill">
                  <img src={assetUrl('/figures/fig-overview-new.png')} alt={`${siteMeta.name} workflow overview`} loading="lazy" />
                  <figcaption>
                    Subspecification generation flow, using stable control-plane behavior as
                    router-level subspecification.
                  </figcaption>
                </figure>
                <ol class="workflow-steps-list">
                  {
                    workflowSteps.map((step, i) => (
                      <li>
                        <span class="step-num">{i + 1}</span>
                        <div>
                          <strong>{step.title}</strong>
                          <p>{step.description}</p>
                        </div>
                      </li>
                    ))
                  }
                </ol>
              </div>
              <figure class="figure-box figure-box--fill">
                <img src={assetUrl('/figures/fig-pipeline-new.png')} alt={`${siteMeta.name} technical pipeline`} loading="lazy" />
                <figcaption>Example of field-level subspec derivation.</figcaption>
              </figure>
            </div>
          </section>
        )
      }

      <section id="trust" class="section">
        <div class="section-title">
          <h2>Why Trust {siteMeta.name}</h2>
        </div>

        <ul class="trust-tabs" role="tablist">
          {
            trustTabs.map((tab, i) => (
              <li>
                <a
                  href="#"
                  class:list={[i === 0 && 'active']}
                  data-trust-tab={tab.id}
                  role="tab"
                  aria-selected={i === 0 ? 'true' : 'false'}
                >
                  {tab.label}
                </a>
              </li>
            ))
          }
        </ul>

        <div class="trust-panel" data-trust-panel="users" role="tabpanel">
          <div class="trust-panel__intro">
            <p class="eval-lead">
              We evaluated {siteMeta.name} with {userStudyMetrics.participants} participants ({userStudyMetrics.operators} professional network operators and {userStudyMetrics.students} graduate students) on four configuration reasoning tasks.
            </p>
            <div class="eval-highlights">
              <span><strong>{userStudyMetrics.accuracyImprovement}</strong> accuracy improvement</span>
              <span><strong>{userStudyMetrics.timeReduction}</strong> time reduction</span>
            </div>
          </div>

          <figure class="figure-box figure-box--wide">
            <EvalChartLegend variant="userstudy" />
            <div class="eval-grid">
              <figure>
                <img src={assetUrl('/figures/fig-userstudy-accuracy-combined.png')} alt="Task accuracy (combined)" loading="lazy" />
                <figcaption>Task accuracy (combined).</figcaption>
              </figure>
              <figure>
                <img src={assetUrl('/figures/fig-userstudy-accuracy-academia.png')} alt="Task accuracy (grad students)" loading="lazy" />
                <figcaption>Task accuracy (grad students).</figcaption>
              </figure>
              <figure>
                <img src={assetUrl('/figures/fig-userstudy-accuracy-industry.png')} alt="Task accuracy (operators)" loading="lazy" />
                <figcaption>Task accuracy (operators).</figcaption>
              </figure>
              <figure>
                <img src={assetUrl('/figures/fig-userstudy-time-combined.png')} alt="Task completion time (combined)" loading="lazy" />
                <figcaption>Task completion time (combined).</figcaption>
              </figure>
              <figure>
                <img src={assetUrl('/figures/fig-userstudy-time-academia.png')} alt="Task completion time (grad students)" loading="lazy" />
                <figcaption>Task completion time (grad students).</figcaption>
              </figure>
              <figure>
                <img src={assetUrl('/figures/fig-userstudy-time-industry.png')} alt="Task completion time (operators)" loading="lazy" />
                <figcaption>Task completion time (operators).</figcaption>
              </figure>
            </div>
            <p class="figure-caption figure-caption--summary">
              User study task accuracy and completion time.
            </p>
          </figure>

          <div class="content-row eval-copy">
            <p>
              Participants scored higher when explanations were available. Combined accuracy rose from
              1.83 to 2.67 points (+52% relative improvement on the paper scale). Task 4 showed the
              largest gain (+78%).
            </p>
            <p>
              Overall median completion time dropped by 24% (9.5 → 7.1 minutes). Graduate students saw
              nearly 2× speedup with subspecs; operators benefited most on the hardest task.
            </p>
          </div>
        </div>

        <div class="trust-panel" data-trust-panel="sus" role="tabpanel" hidden>
          <div class="trust-panel__intro">
            <p class="eval-lead">
              Mean SUS was 62.3/100 overall (71.3 academia, 57.5 industry). 70% of participants
              reported they would use localized subspecifications frequently.
            </p>
            <div class="eval-highlights" aria-hidden="true"></div>
          </div>
          <figure class="figure-box figure-box--wide">
            <EvalChartLegend variant="sus" />
            <div class="eval-grid eval-grid--3">
              <figure>
                <img src={assetUrl('/figures/fig-userstudy-sus-combined.png')} alt="SUS (combined)" loading="lazy" />
                <figcaption>System usability scale (combined).</figcaption>
              </figure>
              <figure>
                <img src={assetUrl('/figures/fig-userstudy-sus-academia.png')} alt="SUS (grad students)" loading="lazy" />
                <figcaption>System usability scale (grad students).</figcaption>
              </figure>
              <figure>
                <img src={assetUrl('/figures/fig-userstudy-sus-industry.png')} alt="SUS (operators)" loading="lazy" />
                <figcaption>System usability scale (operators).</figcaption>
              </figure>
            </div>
          </figure>
        </div>

        <div class="trust-panel" data-trust-panel="scalability" role="tabpanel" hidden>
          <div class="trust-panel__intro">
            <p class="eval-lead">
              We assessed scalability by varying network size, number of prefixes, and parallelism.
            </p>
            <div class="eval-highlights">
              <span><strong>{benchmarkMetrics.fiveHundredRouterMinutes} min</strong> at 500 routers</span>
            </div>
          </div>

          <figure class="figure-box figure-box--wide">
            <EvalChartLegend variant="benchmark-line" />
            <div class="eval-grid eval-grid--3">
              <figure>
                <img src={assetUrl('/figures/fig_benchmark_lineplot_fattrees.png')} alt="Scalability varying network size" loading="lazy" />
                <figcaption>Vary network size.</figcaption>
              </figure>
              <figure>
                <img src={assetUrl('/figures/fig_benchmark_lineplot_synthetic.png')} alt="Scalability varying number of prefixes" loading="lazy" />
                <figcaption>Vary prefixes.</figcaption>
              </figure>
              <figure>
                <img src={assetUrl('/figures/fig_benchmark_lineplot_cores.png')} alt="Scalability varying thread count" loading="lazy" />
                <figcaption>Vary threads (parallelism).</figcaption>
              </figure>
            </div>
            <p class="figure-caption figure-caption--summary">
              Scalability of subspecification generation under different dimensions.
            </p>
          </figure>
        </div>

        <div class="trust-panel" data-trust-panel="runtime" role="tabpanel" hidden>
          <div class="trust-panel__intro">
            <p class="eval-lead">
              We benchmarked end-to-end subspecification generation on real and synthetic network configurations.
            </p>
            <div class="eval-highlights">
              <span><strong>{benchmarkMetrics.internet2Minutes} min</strong> Internet2</span>
              <span><strong>{benchmarkMetrics.syntheticSecondsRange} sec</strong> synthetic configs</span>
            </div>
          </div>

          <figure class="figure-box figure-box--wide">
            <EvalChartLegend variant="benchmark-time" />
            <div class="eval-chart-single">
              <img
                src={assetUrl('/figures/fig_benchmark_times.png')}
                alt="Run time on each network configuration"
                loading="lazy"
              />
            </div>
            <p class="figure-caption figure-caption--summary">Run time on each network configuration.</p>
          </figure>
        </div>

        <p class="content-row trust-footer">
          <a href={projectLinks.paper}>Read the full evaluation →</a>
        </p>
      </section>

      <section id="research" class="section">
        <div class="section-title"><h2>Research Extensions</h2></div>
        <ul class="research-tabs" role="tablist">
          {
            researchTree.map((item, i) => (
              <li>
                <a
                  href="#"
                  class:list={[i === 0 && 'active']}
                  data-research-tab={item.id}
                  role="tab"
                  aria-selected={i === 0 ? 'true' : 'false'}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>

        <div class="research-panel" data-research-panel="core" role="tabpanel">
          <div class="content-row">
            <h4><a href={coreResearch.pdf}>{coreResearch.title}</a></h4>
            <p class="research-meta">
              {coreResearch.venue} · {coreResearch.date} · {coreResearch.location}
            </p>
            <p class="research-meta">{coreResearch.authors.join(', ')}</p>
            <p>{coreResearch.description}</p>
            <p>
              <a href={coreResearch.pdf}>PDF</a>
              {' · '}
              <a href={coreResearch.doi} target="_blank" rel="noopener noreferrer">DOI</a>
            </p>
          </div>
        </div>

        {
          researchExtensions.map((ext) => (
            <div class="research-panel" data-research-panel={ext.id} role="tabpanel" hidden>
              <div class="content-row">
                <h4>{ext.pdf ? <a href={ext.pdf}>{ext.title}</a> : ext.title}</h4>
                <p class="research-meta">
                  {ext.venue}
                  {ext.date ? ` · ${ext.date}` : ''}
                  {ext.location ? ` · ${ext.location}` : ''}
                </p>
                {ext.authors.length > 0 && <p class="research-meta">{ext.authors.join(', ')}</p>}
                <p>{ext.description}</p>
                <p>
                  {ext.pdf && <a href={ext.pdf}>PDF</a>}
                  {ext.doi && (
                    <>
                      {ext.pdf && ' · '}
                      <a href={ext.doi} target="_blank" rel="noopener noreferrer">DOI</a>
                    </>
                  )}
                </p>
              </div>
            </div>
          ))
        }
      </section>
    </div>
  </div>

  <script>
    function setupSectionTabs(tabAttr, panelAttr) {
      document.querySelectorAll(`[${tabAttr}]`).forEach((tab) => {
        tab.addEventListener('click', (e) => {
          e.preventDefault();
          const id = tab.getAttribute(tabAttr);
          if (!id) return;

          document.querySelectorAll(`[${tabAttr}]`).forEach((t) => {
            t.classList.remove('active');
            t.setAttribute('aria-selected', 'false');
          });
          tab.classList.add('active');
          tab.setAttribute('aria-selected', 'true');

          document.querySelectorAll(`[${panelAttr}]`).forEach((panel) => {
            const panelId = panel.getAttribute(panelAttr);
            if (panelId === id) panel.removeAttribute('hidden');
            else panel.setAttribute('hidden', '');
          });
        });
      });
    }

    setupSectionTabs('data-trust-tab', 'data-trust-panel');
    setupSectionTabs('data-research-tab', 'data-research-panel');
  </script>
</BaseLayout>
